    line(branchX, 160, 260, 160); // To Pin 7
    ctx.textAlign = "left"; ctx.fillText("7", 270, 155);

    line(branchX, 260, 260, 260); // To Pins 2, 6
    ctx.fillText("2, 6", 270, 255);

    // Output Pin 3
    line(360, 210, 460, 210);
    ctx.fillText("3", 345, 205);
    ctx.fillText("Output", 470, 215);

    // Power Pins (8, 4 and 1)
    line(310, 140, 310, 40); 
    drawNode(310, 40); // Junction at Vcc
    ctx.fillText("8, 4", 320, 130);
    
    line(310, 280, 310, 380);
    drawNode(310, 380); // Junction at 0V
    ctx.fillText("1", 320, 370);

    // 5. Update Solutions Text
    document.getElementById('solText').innerHTML = 
        "f = 1.44 / ((" + R1 + " + 2*" + R2 + ") * " + C_farads.toExponential(2) + ") = " + freq.toFixed(1) + " Hz<br>" +
        "T = 1 / f = " + period_ms.toFixed(1) + " ms";
}
    
    window.onload = function() { generateProblem(); };
    </script>
