        function drawRoundRect(ctx, x, y, width, height, radius) {
            ctx.beginPath(); ctx.moveTo(x + radius, y); ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius); ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height); ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius); ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y); ctx.closePath(); ctx.fill(); ctx.stroke();
        }

        function generateOscilloscopeProblem(ctx, canvas) {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            ctx.fillStyle = "#e0e5e7"; ctx.strokeStyle = "#888"; ctx.lineWidth = 2; drawRoundRect(ctx, 20, 20, 400, 320, 25);
            ctx.strokeStyle = "#555"; ctx.lineWidth = 1;
            for(let i=0; i<=8; i++) { let y = 20 + i*40; ctx.beginPath(); ctx.moveTo(20, y); ctx.lineTo(420, y); ctx.stroke(); }
            for(let i=0; i<=10; i++) { let x = 20 + i*40; ctx.beginPath(); ctx.moveTo(x, 20); ctx.lineTo(x, 340); ctx.stroke(); }
            ctx.strokeStyle = "#222"; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.moveTo(20, 180); ctx.lineTo(420, 180); ctx.stroke(); 
            ctx.beginPath(); ctx.moveTo(220, 20); ctx.lineTo(220, 340); ctx.stroke(); 
            ctx.lineWidth = 1;
            for(let i=0; i<=50; i++) { let x = 20 + i*8; ctx.beginPath(); ctx.moveTo(x, 175); ctx.lineTo(x, 185); ctx.stroke(); }
            for(let i=0; i<=40; i++) { let y = 20 + i*8; ctx.beginPath(); ctx.moveTo(215, y); ctx.lineTo(225, y); ctx.stroke(); }

            let vGainUnit = Math.random() < 0.5 ? 'V' : 'mV';
            let tBaseUnit = Math.random() < 0.5 ? 'ms' : 's';
            
            let ampDivs = Math.floor(Math.random() * 3) + 1; 
            let vGain = [1, 2, 5][Math.floor(Math.random() * 3)];
            let amplitude = ampDivs * vGain;

            let markDivs = Math.floor(Math.random() * 4) + 1; 
            let spaceDivs = Math.floor(Math.random() * 4) + 1; 
            let tBase = [1, 2, 5, 10, 20, 50][Math.floor(Math.random() * 6)];
            let periodTime = (markDivs + spaceDivs) * tBase;
            
            let frequency = (tBaseUnit === 'ms') ? (1000 / periodTime) : (1 / periodTime);
            frequency = Math.round(frequency * 1000) / 1000;

            ctx.fillStyle = brandBlack; 
            ctx.font = "bold 15px Arial";
            ctx.fillText("Settings:", 430, 80);
            
            ctx.font = "14px Arial";
            ctx.fillText("Time Base:", 430, 110);
            ctx.fillText(tBase + " " + tBaseUnit + " / div", 430, 130);
            
            ctx.fillText("Voltage Gain:", 430, 170);
            ctx.fillText(vGain + " " + vGainUnit + " / div", 430, 190);

            ctx.strokeStyle = brandBlack; ctx.lineWidth = 3; ctx.lineJoin = "bevel";
            let path = []; let phaseDivs = Math.floor(Math.random() * (markDivs + spaceDivs)); 
            for(let px = 20; px <= 420; px++) {
                let divOffset = (px - 20) / 40;
                let currentCycleTime = (divOffset + phaseDivs) % (markDivs + spaceDivs);
                let y = (currentCycleTime < markDivs) ? 180 - (ampDivs * 40) : 180; 
                path.push({x: px, y: y});
            }
            ctx.beginPath(); ctx.moveTo(path[0].x, path[0].y);
            for(let i=1; i<path.length; i++) {
                if(path[i].y !== path[i-1].y) { ctx.lineTo(path[i].x, path[i-1].y); ctx.lineTo(path[i].x, path[i].y); } 
                else { ctx.lineTo(path[i].x, path[i].y); }
            }
            ctx.stroke();

            const qTypes = [
                { text: "Mark Time = ", ans: markDivs * tBase, unit: tBaseUnit, sol: markDivs + " divs &times; " + tBase + " " + tBaseUnit + "/div" },
                { text: "Space Time = ", ans: spaceDivs * tBase, unit: tBaseUnit, sol: spaceDivs + " divs &times; " + tBase + " " + tBaseUnit + "/div" },
                { text: "Time Period = ", ans: periodTime, unit: tBaseUnit, sol: "(" + markDivs + " + " + spaceDivs + ") divs &times; " + tBase + " " + tBaseUnit + "/div" },
                { text: "Frequency = ", ans: frequency, unit: "Hz", sol: (tBaseUnit === 'ms' ? "1 / (" + periodTime + " / 1000) s" : "1 / " + periodTime + " s") },
                { text: "Mark/Space Ratio = ", ans: markDivs / spaceDivs, unit: "ratio", sol: "Mark takes " + markDivs + " divs, Space takes " + spaceDivs + " divs. Fraction is " + markDivs + "/" + spaceDivs + "." }
            ];

            const q = qTypes[Math.floor(Math.random() * qTypes.length)];
            currentAnswers.osc1Value = amplitude; currentAnswers.osc1Unit = vGainUnit;
            currentAnswers.osc2Value = q.ans; currentAnswers.osc2Unit = q.unit;

            document.getElementById('labelOsc2').innerHTML = q.text;
            if (q.unit === 'ratio') {
                document.getElementById('inputOsc2').placeholder = "e.g. 1/2";
            } else if (q.unit === 'Hz') {
                document.getElementById('inputOsc2').placeholder = "e.g. 50 Hz";
            } else {
                document.getElementById('inputOsc2').placeholder = "e.g. 20 " + q.unit; 
            }

            const solText = document.getElementById('solText');
            if (solText) solText.innerHTML = 
                "<strong>Amplitude = " + amplitude + " " + vGainUnit + "</strong><br>" +
                "<em>Logic:</em> Wave height is " + ampDivs + " divs. " + ampDivs + " &times; " + vGain + " " + vGainUnit + "/div = " + amplitude + " " + vGainUnit + ".<br><br>" +
                "<strong>" + q.text.replace(" = ", "") + " = " + (q.unit === 'ratio' ? markDivs + "/" + spaceDivs : q.ans + " " + q.unit) + "</strong><br>" + 
                "<em>Logic:</em> " + q.sol;
        }

       function checkAnswers() {
            if (isCurrentProblemSolved) return; 

            const feedback = document.getElementById('feedback');
            const helpBtn = document.getElementById('helpBtn');

            // 1. Check if the relevant active boxes are genuinely blank first
            let activeInputs = [];
            if (currentMode === 'analysis') activeInputs = ['inputV', 'inputI'];
            else if (currentMode === 'divider') activeInputs = ['inputV'];
            else if (currentMode === 'resistance') activeInputs = ['inputR'];
            else if (currentMode === 'oscilloscope') activeInputs = ['inputOsc1', 'inputOsc2'];

            let hasEmptyBox = false;
            activeInputs.forEach(id => {
                if (document.getElementById(id).value.trim() === '') {
                    hasEmptyBox = true;
                }
            });

            // If a box is empty, warn them and stop without counting as an attempt
            if (hasEmptyBox) {
                feedback.innerHTML = "<span style='color: #dc3545;'>Please enter a value!</span>";
                return; 
            }
            
            // 2. Mark the problem as attempted
            if (!hasCheckedCurrentProblem) { 
                problemsAttempted++; 
                hasCheckedCurrentProblem = true; 
            }

            // 3. Parse inputs against expected answers
            let results = [];
            if (currentMode === 'analysis') {
                let pV = parseInput(document.getElementById('inputV').value);
                let pI = parseInput(document.getElementById('inputI').value);
                results.push(validateMatch(pV, currentAnswers.vValue, currentAnswers.vUnit));
                results.push(validateMatch(pI, currentAnswers.iValue, currentAnswers.iUnit));
            } else if (currentMode === 'divider') {
                let pV = parseInput(document.getElementById('inputV').value);
                results.push(validateMatch(pV, currentAnswers.vValue, currentAnswers.vUnit));
            } else if (currentMode === 'resistance') {
                let pR = parseInput(document.getElementById('inputR').value);
                results.push(validateMatch(pR, currentAnswers.rValue, currentAnswers.rUnit));
            } else if (currentMode === 'oscilloscope') {
                let pO1 = parseInput(document.getElementById('inputOsc1').value);
                let pO2 = parseInput(document.getElementById('inputOsc2').value);
                results.push(validateMatch(pO1, currentAnswers.osc1Value, currentAnswers.osc1Unit));
                results.push(validateMatch(pO2, currentAnswers.osc2Value, currentAnswers.osc2Unit));
            }
           else if (currentMode === 'astable') {
        const aF = parseInput(document.getElementById('inputAstable').value);
        const aT = parseInput(document.getElementById('inputAstableT').value);
        results.push(validateMatch(aF, currentAnswers.astableValue, currentAnswers.astableUnit));
        results.push(validateMatch(aT, currentAnswers.astableTValue, currentAnswers.astableTUnit));
        }

            // 4. Grade the results
            if (results.every(r => r === 'correct')) {
                isCurrentProblemSolved = true;
                
                if (!viewedSolution && !unitErrorMade) {
                    problemsCorrect++;
                    feedback.innerHTML = "<span style='color: #198754;'>Correct! Great job!</span>";
                } else if (unitErrorMade) {
                    feedback.innerHTML = "<span style='color: #fd7e14;'>Correct! (No point awarded due to earlier unit error).</span>";
                } else {
                    feedback.innerHTML = "<span style='color: #E64097;'>Correct! (Solution viewed).</span>";
                }
                
                if (helpBtn) helpBtn.style.display = 'none';
            } else {
                if (helpBtn) helpBtn.style.display = 'block';
                
                if (results.includes('nounit')) {
                    unitErrorMade = true;
                    feedback.innerHTML = "<span style='color: #fd7e14;'>Don't forget your units! (Mark lost for this question)</span>";
                } else if (results.includes('wrongunit')) {
                    unitErrorMade = true;
                    if (currentMode === 'oscilloscope' && currentAnswers.osc2Unit === 'ratio') {
                        feedback.innerHTML = "<span style='color: #fd7e14;'>Almost! The Mark/Space ratio must be written as a fraction (e.g. 1/2).</span>";
                    } else {
                        feedback.innerHTML = "<span style='color: #fd7e14;'>Number is right, units are wrong! (Mark lost for this question)</span>";
                    }
                } else if (results.some(r => r === 'correct')) {
                    feedback.innerHTML = "<span style='color: #dc3545;'>One is right, one is wrong. Check logic!</span>";
                } else {
                    // This now handles math errors AND weird/incorrect units correctly
                    feedback.innerHTML = "<span style='color: #dc3545;'>Incorrect. Check your math!</span>";
                }
            }
            
            updateScoreboard();
        }

